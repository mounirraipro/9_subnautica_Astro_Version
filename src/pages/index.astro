---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articles } from "@/data/articles";
import { faqItems, features, gameMeta, stats, survivalLoop } from "@/data/gameData";
import { siteConfig } from "@/data/siteConfig";

const recentPosts = articles.slice(0, 3);
const lobbyCards = [
  { href: "/play/", title: "Subnautica Online", shortTitle: "Play Now", category: "Now playing", accentClass: "accent-sky" },
  { href: "/how-to-play/", title: "First Dive Route", shortTitle: "First Dives", category: "Beginner", accentClass: "accent-green" },
  { href: "/blog/crafting-priorities/", title: "Crafting Priorities", shortTitle: "Crafting", category: "Guide", accentClass: "accent-gold" },
  { href: "/blog/base-building-guide/", title: "Base Building Guide", shortTitle: "Base Building", category: "Guide", accentClass: "accent-blue" },
  { href: "/blog/biome-progression/", title: "Biome Progression", shortTitle: "Biomes", category: "Explore", accentClass: "accent-sky" },
  { href: "/blog/creature-safety/", title: "Creature Safety", shortTitle: "Safety", category: "Survival", accentClass: "accent-coral" },
  { href: "/strategy/", title: "Strategy Guide", shortTitle: "Strategy", category: "Planning", accentClass: "accent-green" },
  { href: "/game-mechanics/", title: "Survival Systems", shortTitle: "Systems", category: "Mechanics", accentClass: "accent-violet" },
].map((card) => ({ ...card, thumbnail: "/subnautica-og.svg" }));
const lobbyLeft = lobbyCards.slice(0, 4);
const lobbyRight = lobbyCards.slice(4, 8);

const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "VideoGame",
    name: siteConfig.name,
    alternateName: ["Subnautica Online", "Subnautica Browser Game"],
    url: `${siteConfig.siteUrl}/`,
    image: new URL(siteConfig.defaultOgImage, siteConfig.siteUrl).href,
    description: siteConfig.description,
    applicationCategory: "Game",
    gamePlatform: ["Web browser", "Desktop", "Mobile", "Tablet"],
    genre: ["Survival", "Adventure", "Exploration"],
    operatingSystem: "Any modern browser",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
    },
    publisher: {
      "@type": "Organization",
      name: siteConfig.publisherName,
      url: siteConfig.siteUrl,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(([question, answer]) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: {
        "@type": "Answer",
        text: answer,
      },
    })),
  },
];
---

<BaseLayout title={siteConfig.name} description={siteConfig.description} structuredData={homeStructuredData}>
  <section class="hero-play">
    <div class="home-game-lobby">
      <div class="game-bento-grid game-bento-grid-side" aria-label="Subnautica quick links">
        {lobbyLeft.map((card, index) => (
          <a class:list={["game-bento-card", card.accentClass, { "game-bento-card-featured": index === 0 }]} href={card.href}>
            <img src={card.thumbnail} alt={`${card.title} preview`} width="640" height="360" loading="lazy" />
            <div>
              <span>{card.category}</span>
              <strong>{card.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
      <div class="hero-game">
        <iframe src={gameMeta.iframeUrl} title="Play Subnautica" loading="eager" allow="autoplay; fullscreen *" allowfullscreen></iframe>
      </div>
      <div class="game-bento-grid game-bento-grid-side" aria-label="More Subnautica guides">
        {lobbyRight.map((card, index) => (
          <a class:list={["game-bento-card", card.accentClass, { "game-bento-card-featured": index === 0 }]} href={card.href}>
            <img src={card.thumbnail} alt={`${card.title} preview`} width="640" height="360" loading="lazy" />
            <div>
              <span>{card.category}</span>
              <strong>{card.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
    </div>
    <div class="hero-copy">
      <div class="hero-copy-main">
        <p class="eyebrow">Underwater survival</p>
        <h1>Subnautica Online</h1>
        <p>Explore an alien ocean in your browser. Gather resources, craft essential tools, build safe habitats, and descend only when your oxygen plan is ready.</p>
        <a class="text-link hero-note" href="/how-to-play/">Learn the first dive route</a>
      </div>
      <div class="hero-play-panel">
        <div class="hero-panel-top">
          <span>Ready in browser</span>
          <strong>No download required.</strong>
        </div>
        <div class="hero-actions">
          <a class="primary-action" href="/play/"><span class="play-triangle"></span>Play Full Screen</a>
          <a class="secondary-action" href="/strategy/">Strategy</a>
        </div>
        <dl class="stat-row">
          {stats.map((stat) => (
            <div><dt>{stat.value}</dt><dd>{stat.label}</dd></div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <section class="home-section home-search-intent">
    <div class="home-section-head split-head">
      <div>
        <p class="eyebrow">Survival loop</p>
        <h2>Each dive should bring you back stronger.</h2>
      </div>
      <p>Subnautica is most satisfying when every trip has a purpose: gather, scan, craft, mark a route, or prepare for the next depth milestone.</p>
    </div>
    <div class="process-strip">
      {survivalLoop.map((item, index) => (
        <article>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="home-section home-worlds">
    <div class="home-section-head">
      <p class="eyebrow">Why it works</p>
      <h3>Exploration with real pressure.</h3>
      <p>The ocean is beautiful, but air, distance, food, tools, and hostile creatures make every discovery feel earned.</p>
    </div>
    <div class="process-strip">
      {features.map((feature) => (
        <article>
          <span>+</span>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="home-section home-process">
    <div class="home-section-head split-head">
      <div>
        <p class="eyebrow">First session</p>
        <h3>Start shallow. Build confidence.</h3>
      </div>
      <p>Use the early game to learn oxygen timing, recipe costs, local resources, and the rhythm of safe returns.</p>
    </div>
    <div class="process-strip">
      <article><span>01</span><h3>Collect</h3><p>Gather titanium, quartz, copper, acid mushrooms, food, and water sources near the pod.</p></article>
      <article><span>02</span><h3>Craft</h3><p>Build a scanner, repair tool, knife, fins, and a larger oxygen tank before going far.</p></article>
      <article><span>03</span><h3>Scan</h3><p>Wreck fragments unlock the blueprints that move the game forward.</p></article>
      <article><span>04</span><h3>Mark</h3><p>Use beacons for wrecks, caves, resources, and routes that deserve a return trip.</p></article>
    </div>
  </section>

  <section class="home-section home-blog">
    <div class="blog-editorial">
      <div class="home-section-head">
        <p class="eyebrow">From the guides</p>
        <h3>Better dives, fewer losses.</h3>
        <p>Short reads for survival planning, crafting priorities, bases, and deep exploration.</p>
        <a class="text-link" href="/blog/">Browse all guides</a>
      </div>
      <div class="blog-board">
        {recentPosts[0] && (
          <a class="editorial-card editorial-card-featured" href={`/blog/${recentPosts[0].slug}/`}>
            <span>{recentPosts[0].category}</span>
            <h3>{recentPosts[0].title}</h3>
            <p>{recentPosts[0].description}</p>
            <small>{recentPosts[0].readTime}</small>
          </a>
        )}
        <div class="article-rail">
          {recentPosts.slice(1).map((post) => (
            <a class="editorial-card editorial-card-row" href={`/blog/${post.slug}/`}>
              <span>{post.category}</span>
              <h3>{post.title}</h3>
              <small>{post.readTime}</small>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-faq">
    <div class="faq-layout">
      <div class="faq-cardlet">
        <p class="eyebrow">FAQ</p>
        <h3>Quick answers.</h3>
        <p>Check device support, progress, and player safety before you dive.</p>
      </div>
      <div class="faq-list" data-faq-list>
        {faqItems.map(([question, answer]) => (
          <details>
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="home-cta">
    <div>
      <p class="eyebrow">Ready?</p>
      <h3>Open the lifepod and start your first dive.</h3>
    </div>
    <a class="primary-action" href="/play/"><span class="play-triangle"></span>Play Subnautica</a>
  </section>

  <script is:inline>
    (() => {
      document.querySelectorAll("[data-faq-list]").forEach((list) => {
        list.querySelectorAll("details").forEach((item) => {
          item.addEventListener("toggle", () => {
            if (!item.open) return;
            list.querySelectorAll("details[open]").forEach((other) => {
              if (other !== item) other.open = false;
            });
          });
        });
      });
    })();
  </script>
</BaseLayout>
