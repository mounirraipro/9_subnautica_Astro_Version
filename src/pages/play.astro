---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { gameMeta, playSteps, tips } from "@/data/gameData";
import { siteConfig } from "@/data/siteConfig";

const lobbyCards = [
  { href: "/how-to-play/", title: "How to Play", shortTitle: "First Dives", category: "Guide", accentClass: "accent-green" },
  { href: "/blog/getting-started/", title: "Getting Started", shortTitle: "Start Safe", category: "Beginner", accentClass: "accent-sky" },
  { href: "/blog/crafting-priorities/", title: "Crafting Priorities", shortTitle: "Crafting", category: "Tools", accentClass: "accent-gold" },
  { href: "/blog/base-building-guide/", title: "Base Building", shortTitle: "Build Base", category: "Habitat", accentClass: "accent-blue" },
  { href: "/blog/biome-progression/", title: "Biome Progression", shortTitle: "Biomes", category: "Explore", accentClass: "accent-sky" },
  { href: "/blog/creature-safety/", title: "Creature Safety", shortTitle: "Safety", category: "Survival", accentClass: "accent-coral" },
  { href: "/strategy/", title: "Strategy Guide", shortTitle: "Strategy", category: "Planning", accentClass: "accent-green" },
  { href: "/game-mechanics/", title: "Survival Systems", shortTitle: "Systems", category: "Mechanics", accentClass: "accent-violet" },
].map((card) => ({ ...card, thumbnail: "/subnautica-og.svg" }));
const lobbyLeft = lobbyCards.slice(0, 4);
const lobbyRight = lobbyCards.slice(4, 8);
---

<BaseLayout
  title={`Play ${siteConfig.name} Online`}
  description={`Play ${siteConfig.name} online free in your browser. Explore, craft, build, and survive with no download or account.`}
>
  <section class="play-stage" id="top">
    <div class="play-stage-bg" aria-hidden="true"></div>
    <div class="home-game-lobby play-game-lobby">
      <div class="game-bento-grid game-bento-grid-side" aria-label="Subnautica guide links">
        {lobbyLeft.map((card, index) => (
          <a class:list={["game-bento-card", card.accentClass, { "game-bento-card-featured": index === 0 }]} href={card.href}>
            <img src={card.thumbnail} alt={`${card.title} preview`} width="640" height="360" loading="lazy" />
            <div>
              <span>{card.category}</span>
              <strong>{card.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
      <div class="play-shell" data-game-shell>
        <iframe src={gameMeta.iframeUrl} title="Subnautica game" allow="autoplay; fullscreen *" allowfullscreen></iframe>
        <div class="play-float-controls">
          <button type="button" data-share-game aria-label="Share game">
            <span>Share</span>
          </button>
          <button type="button" data-fullscreen-game aria-label="Fullscreen game">
            <span>Fullscreen</span>
          </button>
        </div>
      </div>
      <div class="game-bento-grid game-bento-grid-side" aria-label="More Subnautica guides">
        {lobbyRight.map((card, index) => (
          <a class:list={["game-bento-card", card.accentClass, { "game-bento-card-featured": index === 0 }]} href={card.href}>
            <img src={card.thumbnail} alt={`${card.title} preview`} width="640" height="360" loading="lazy" />
            <div>
              <span>{card.category}</span>
              <strong>{card.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="play-info-section">
    <div class="play-info-head">
      <p class="eyebrow">Play online</p>
      <h1>Subnautica in your browser.</h1>
      <p>Dive into alien water, gather resources, craft better tools, and build enough safety to explore deeper.</p>
    </div>
    <div class="play-step-grid">
      {playSteps.map((step, index) => (
        <article>
          <span>{String(index + 1)}</span>
          <strong>{step.title}</strong>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="play-info-section play-split-section">
    <div>
      <p class="eyebrow">Core loop</p>
      <p class="play-panel-title">Dive with a goal, return with progress.</p>
      <div class="play-category-pills">
        <a class="accent-sky" href="/how-to-play/">First Dives</a>
        <a class="accent-green" href="/strategy/">Strategy</a>
        <a class="accent-blue" href="/game-mechanics/">Survival Systems</a>
      </div>
    </div>
    <div class="play-tip-panel">
      <p class="eyebrow">Tips</p>
      <ul>
        {tips.map((tip) => <li>{tip}</li>)}
      </ul>
    </div>
  </section>

  <section class="play-info-section seo-copy-section" aria-labelledby="play-page-guide">
    <div class="section-head">
      <h2 id="play-page-guide">Play guide.</h2>
    </div>
    <div class="seo-copy-grid">
      <article class="seo-copy-card seo-copy-wide">
        <h3>Why preparation matters</h3>
        <p>Subnautica turns distance into risk. A deeper dive asks for more oxygen, better tools, a known route, and a reason to go there. The strongest players do not rush the ocean; they turn each safe return into a better next expedition.</p>
      </article>
      <article class="seo-copy-card">
        <h3>How to start well</h3>
        <p>Stay close to the lifepod, craft the scanner, repair key systems, gather common materials, and follow early radio signals only after your oxygen and movement tools improve.</p>
      </article>
      <article class="seo-copy-card">
        <h3>Best sessions</h3>
        <p>Use short sessions for resource loops and longer sessions for wreck scanning, base building, or deep route planning. Save behavior depends on browser storage, so avoid clearing site data mid-play.</p>
      </article>
    </div>
  </section>
  <script is:inline>
    (() => {
      const shell = document.querySelector("[data-game-shell]");
      const iframe = shell?.querySelector("iframe");
      const fullscreen = document.querySelector("[data-fullscreen-game]");
      const share = document.querySelector("[data-share-game]");
      fullscreen?.addEventListener("click", async () => {
        const active = document.fullscreenElement;
        if (active) {
          await document.exitFullscreen?.();
          return;
        }
        await (iframe?.requestFullscreen?.() ?? shell?.requestFullscreen?.());
      });
      share?.addEventListener("click", async () => {
        const data = { title: "Subnautica", text: "Play Subnautica online.", url: location.href };
        try {
          if (navigator.share) await navigator.share(data);
          else await navigator.clipboard?.writeText(location.href);
        } catch {}
      });
    })();
  </script>
</BaseLayout>
